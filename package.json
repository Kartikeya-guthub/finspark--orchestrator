{
  "name": "finspark-orchestrator",
  "private": true,
  "version": "0.1.0",
  "description": "Phase-locked monorepo for Finspark Orchestrator",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "npx tsx apps/api/index.ts",
    "seed:registry": "npx tsx scripts/seed-registry.ts",
    "migrate": "node scripts/migrate.mjs",
    "seed": "node scripts/seed.mjs",
    "migrate:fresh": "node scripts/migrate.mjs && node scripts/seed.mjs",
    "demo:seed": "node scripts/seed.mjs && node scripts/demo-seed.mjs",
    "demo:run": "bash scripts/run-demo.sh",
    "health:check": "node scripts/health-check.mjs",
    "demo:ready:check": "bash scripts/demo-ready-check.sh",
    "test": "node scripts/test-plain.mjs",
    "dev:api": "npm --workspace @finspark/api run dev",
    "dev:ai": "uvicorn app.main:app --app-dir apps/ai-service --host 0.0.0.0 --port 8002 --reload",
    "health:api": "npm --workspace @finspark/api run dev",
    "health:web": "npm --workspace @finspark/web run health",
    "health:simulator": "npm --workspace @finspark/simulator run dev",
    "health:ai": "uvicorn app.main:app --app-dir apps/ai-service --host 0.0.0.0 --port 8002"
  },
  "dependencies": {
    "fastify": "^5.8.4",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "ts-node": "^10.9.2"
  }
}
